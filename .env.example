# ─────────────────────────────────────────────
#  SharCode — Variables d'environnement
#  Copiez ce fichier en .env et adaptez les valeurs
# ─────────────────────────────────────────────

# Clé secrète Flask — OBLIGATOIRE en production
# Générez une valeur aléatoire : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-en-production

# Chemin vers la base de données SQLite
# En Docker, ce chemin pointe vers le volume /data
DATABASE_PATH=/data/sharcode.db

# Environnement (production | development)
FLASK_ENV=production

# Port d'écoute (optionnel, défaut : 5000)
PORT=5000

# Compte administrateur (créé au 1er démarrage si inexistant)
# CHANGEZ ces valeurs avant de déployer en production !
ADMIN_EMAIL=admin@sharcode.fr
ADMIN_PASSWORD=Admin2024!
